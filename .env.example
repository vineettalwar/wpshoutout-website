# WP Shoutout — Environment Variables
# Copy this file to .env and fill in the values.
# On Replit, use the Secrets tab instead of this file.

# ── API Server ────────────────────────────────────────────────────────────────
# Port the API server listens on
PORT=3001

# Resend API key for contact form emails. Get from https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_KEY_HERE

# Contact form recipient email
CONTACT_EMAIL=hello@wpshoutout.com

# Contact form sender address (must match a verified Resend sending domain)
CONTACT_FROM_EMAIL=WP Shoutout <noreply@wpshoutout.com>

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required for db migrate, optional for dev)
DATABASE_URL=postgres://user:password@localhost:5432/wpshoutout

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Port the Vite dev server listens on
# PORT=5173  (set separately when running the frontend)

# Base path for the Vite app (use / for local development)
BASE_PATH=/

# Full URL of the API server (leave empty to use same-origin / Replit proxy)
# VITE_API_BASE_URL=http://localhost:3001
